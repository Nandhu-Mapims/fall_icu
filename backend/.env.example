# Purpose: Environment variables template for ICU fall detection backend.
APP_NAME=ICU Fall Detection API
API_PREFIX=/api/v1
# Fastest: local TensorRT .engine (requires TensorRT + matching CUDA). INFERENCE_IMAGE_SIZE must match export imgsz.
MODEL_PATH=models/yolo26n-pose.engine
# Load order when MODEL_PATH ends in .engine: .engine file -> same-stem .onnx -> .pt (Ultralytics docs: format engine|onnx|pt).
#
# Export (Python): model = YOLO("yolo26n-pose.pt"); model.export(format="onnx")  # or format="engine"
# CLI: yolo export model=yolo26n-pose.pt format=onnx imgsz=960 device=0
#      yolo export model=yolo26n-pose.pt format=engine imgsz=960 device=0 half=True
# Scripts (from backend/): python scripts/export_onnx_model.py --output models/yolo26n-pose.onnx
#                          python scripts/export_tensorrt_engine.py --output models/yolo26n-pose.engine
# Set true only if TensorRT matches your CUDA/driver (otherwise you get CUDA error 35). Default false = use PyTorch when .engine missing.
TENSORRT_AUTO_EXPORT_IF_MISSING=false
# If true, use PyTorch when .engine is missing or TensorRT export failed (recommended; TensorRT needs matching CUDA/driver).
TENSORRT_ALLOW_PYTORCH_FALLBACK=true
# If false and models/<stem>.onnx exists from a failed export, skip re-exporting (faster restarts). Set true to force retry.
TENSORRT_RETRY_EXPORT_AFTER_ONNX=false
# YOLO person/pose detection confidence (lower = more sensitive, more false boxes).
CONFIDENCE_THRESHOLD=0.25
# Per-joint minimum for fall heuristics (shoulders, hips, knees, etc.); lower = more fall paths can activate.
KEYPOINT_CONFIDENCE_MIN=0.2
# 960–1280 typical for 6GB; lower if CUDA OOM.
INFERENCE_IMAGE_SIZE=960
MAX_PEOPLE_PER_FRAME=8
USE_HALF_PRECISION=true
# true = FP32 on GPU (~2x VRAM vs FP16), often slower
USE_FP32_GPU_INFERENCE=false
CUDA_DEVICE=0
MODEL_WARMUP_RUNS=2
REQUEST_TIMEOUT_SECONDS=20
REQUIRE_CUDA=true
